# =============================================================================
#  local.rules — Equipe 1
#  Round : Injection SQL
#  IMPORTANT : chaque regle sur UNE SEULE LIGNE
#  Recharger : docker exec suricata suricatasc -c reload-rules
#  Alertes   : docker exec suricata tail -f /var/log/suricata/fast.log
# =============================================================================

# Ajoutez vos regles ci-dessous (sid : 10XX)
# Exemple :
# alert http any any -> $HTTP_SERVERS any (msg:"Exemple"; flow:established,to_server; http.uri; content:"test"; nocase; sid:1001; rev:1;)


regle 1 :
alert http any any -> $HTTP_SERVERS any (msg:"WEB - Tentative injection SQL UNION SELECT detectee"; flow:established,to_server; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:1; pcre:"/UNION(\+|\s|%20)SELECT/Ui"; classtype:web-application-attack; sid:1000002; rev:2;)
