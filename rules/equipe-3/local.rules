# =============================================================================
#  local.rules — Equipe 3
#  Round : Injection SQL
#  IMPORTANT : chaque regle sur UNE SEULE LIGNE
#  Recharger : docker exec suricata suricatasc -c reload-rules
#  Alertes   : docker exec suricata tail -f /var/log/suricata/fast.log
