# -----------------------------------------------------------------------------
# MODULE 3 — Exercice B : injection SQL UNION SELECT
# Objectif : détecter UNION SELECT dans les URI HTTP
# -----------------------------------------------------------------------------
# TODO : décommenter et compléter
# alert http any any -> $HTTP_SERVERS any (msg:"TODO - Injection SQL UNION SELECT"; flow:established,to_server; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:1; sid:1000002; rev:1;)

# Solution (décommenter pour vérifier) :
alert http any any -> $HTTP_SERVERS any (msg:"WEB - Tentative injection SQL UNION SELECT"; flow:established,to_server; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:1; classtype:web-application-attack; sid:1000002; rev:1;)
