# =============================================================================
#  local.rules — Equipe 5
#  Round : Injection SQL complet
# =============================================================================

# 1️⃣ Attaques logiques classiques
alert http any any -> $HTTP_SERVERS any (msg:"SQLi OR 1=1"; flow:established,to_server; http.uri; content:"or 1=1"; nocase; sid:5101; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi OR 1=1 comment --"; flow:established,to_server; http.uri; content:"or 1=1--"; nocase; sid:5102; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi quote OR quote"; flow:established,to_server; http.uri; content:"' or '"; nocase; sid:5103; rev:1;)

# 2️⃣ UNION SELECT
alert http any any -> $HTTP_SERVERS any (msg:"SQLi UNION SELECT"; flow:established,to_server; http.uri; content:"union select"; nocase; sid:5104; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi UNION SELECT URL encoded"; flow:established,to_server; http.uri; pcre:"/union\s*select/i"; sid:5105; rev:1;)

# 3️⃣ Commandes SQL
alert http any any -> $HTTP_SERVERS any (msg:"SQLi SELECT keyword"; flow:established,to_server; http.uri; content:"select "; nocase; sid:5106; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi INSERT keyword"; flow:established,to_server; http.uri; content:"insert "; nocase; sid:5107; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi UPDATE keyword"; flow:established,to_server; http.uri; content:"update "; nocase; sid:5108; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi DELETE keyword"; flow:established,to_server; http.uri; content:"delete "; nocase; sid:5109; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi DROP keyword"; flow:established,to_server; http.uri; content:"drop "; nocase; sid:5110; rev:1;)

# 4️⃣ Schémas et temps
alert http any any -> $HTTP_SERVERS any (msg:"SQLi information_schema"; flow:established,to_server; http.uri; content:"information_schema"; nocase; sid:5111; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi sleep time attack"; flow:established,to_server; http.uri; content:"sleep("; nocase; sid:5112; rev:1;)

# 5️⃣ Contournement avec commentaires
alert http any any -> $HTTP_SERVERS any (msg:"SQLi comment --"; flow:established,to_server; http.uri; content:"--"; nocase; sid:5113; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SQLi comment #"; flow:established,to_server; http.uri; content:"#"; nocase; sid:5114; rev:1;)

# 6️⃣ Caractères spéciaux
alert http any any -> $HTTP_SERVERS any (msg:"SQLi semicolon"; flow:established,to_server; http.uri; content:";"; nocase; sid:5115; rev:1;)

# 7️⃣ Catch-all regex pour tout SELECT, UNION, INSERT, DROP encodé ou obfusqué
alert http any any -> $HTTP_SERVERS any (msg:"SQLi possible SELECT/UNION/INSERT/DROP obfusqué"; flow:established,to_server; http.uri; pcre:"/(select|union|insert|drop|delete|update)/i"; sid:5116; rev:1;)

